<Application x:Class="laba_9_MVVM.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:laba_9_MVVM.Views"
             xmlns:viewmodels="clr-namespace:laba_9_MVVM.ViewModels">
    <Application.Resources>
        <!-- Связываем типы ViewModel с соответствующими View. 
             WPF автоматически выбирает нужный UserControl при отображении объекта ViewModel. -->
        <DataTemplate DataType="{x:Type viewmodels:ContactsListViewModel}">
            <views:ContactsListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:AboutViewModel}">
            <views:AboutView/>
        </DataTemplate>
    </Application.Resources>
</Application>
