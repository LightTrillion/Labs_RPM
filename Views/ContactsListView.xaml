             d:DataContext="{d:DesignInstance Type=vm:ContactsListViewModel}">
	<Grid Margin="10">
		<!-- Contacts list layout from Lab 10 -->
		<DataGrid ItemsSource="{Binding Contacts}" AutoGenerateColumns="True"/>
		<!-- Add/Remove buttons -->
	</Grid>
</UserControl>