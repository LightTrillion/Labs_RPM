<Window x:Class="laba_9_MVVM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        xmlns:vm="clr-namespace:laba_9_MVVM.ViewModels"
        d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}"
        Title="Телефонная книга" Height="450" Width="800">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>
		<!-- Menu for navigation -->
		<Menu Grid.Row="0" Background="WhiteSmoke">
			<MenuItem Header="Контакты" Command="{Binding ShowContactsCommand}"/>
			<MenuItem Header="О программе" Command="{Binding ShowAboutCommand}"/>
		</Menu>
		<!-- Content area that automatically picks View by DataTemplate -->
		<ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}"
                        Margin="10"/>
	</Grid>
</Window>